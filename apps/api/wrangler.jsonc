{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-11",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "monorepo_db",
      "database_id": "<your-database-id>",
      "migrations_dir": "src/db/migrations",
    },
  ],
}
